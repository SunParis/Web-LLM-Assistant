{
  "manifest_version": 3,
  "name": "Web LLM Assistant",
  "version": "0.2.2",
  "description": "A page-aware LLM assistant with side panel chat and selected-text context.",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "sidePanel",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Web LLM Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "commands": {
    "_execute_action": {}
  }
}
